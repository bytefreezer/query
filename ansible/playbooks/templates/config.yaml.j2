# ByteFreezer Query Configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# Host: {{ inventory_hostname }}

app:
  name: {{ config.app.name }}
  version: {{ config.app.version }}

# Logging configuration
logging:
  level: {{ config.logging.level }}
  encoding: {{ config.logging.encoding }}

# Server configuration
server:
  port: {{ config.server.port }}

# S3/MinIO configuration for Parquet data access
s3:
  region: "{{ config.s3.region }}"
  access_key: "{{ config.s3.access_key }}"
  secret_key: "{{ config.s3.secret_key }}"
  bucket: "{{ config.s3.bucket }}"
{% if config.s3.account_id | default('') %}
  account_id: "{{ config.s3.account_id }}"
{% endif %}
{% if config.s3.endpoint %}
  endpoint: "{{ config.s3.endpoint }}"
{% endif %}
  ssl: {{ config.s3.ssl | lower }}
  url_style: "{{ config.s3.url_style }}"
  use_iam_role: {{ config.s3.use_iam_role | lower }}

# LLM configuration
llm:
  provider: "{{ config.llm.provider }}"
  api_key: "{{ claude_api_key | default('') }}"
  model: "{{ config.llm.model }}"
{% if config.llm.provider == 'ollama' %}
  ollama_host: "{{ config.llm.ollama_host }}"
{% endif %}

# Demo limits
limits:
  max_time_range_hours: {{ config.limits.max_time_range_hours | default(24) }}
  max_row_limit: {{ config.limits.max_row_limit | default(100) }}
  allow_order_by: {{ config.limits.allow_order_by | default(false) | lower }}
