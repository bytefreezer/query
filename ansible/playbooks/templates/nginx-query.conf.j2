# ByteFreezer Query (AI-powered log analysis)
server {
    listen 443 ssl http2;
    server_name query.bytefreezer.com;

    ssl_certificate /etc/letsencrypt/live/bytefreezer.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bytefreezer.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:{{ config.server.port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 120;
    }
}

# HTTP redirect for query subdomain
server {
    listen 80;
    server_name query.bytefreezer.com;
    return 301 https://$host$request_uri;
}
