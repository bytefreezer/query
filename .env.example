# ByteFreezer Query Service Environment Variables
# These override config.yaml values

# S3 Configuration
BYTEFREEZER_QUERY_S3_REGION=us-west-2
BYTEFREEZER_QUERY_S3_ACCESS_KEY=your-access-key
BYTEFREEZER_QUERY_S3_SECRET_KEY=your-secret-key
BYTEFREEZER_QUERY_S3_BUCKET=your-bucket-name
BYTEFREEZER_QUERY_S3_DATA_PATH=data/

# For MinIO (optional)
# BYTEFREEZER_QUERY_S3_ENDPOINT=http://minio:9000
# BYTEFREEZER_QUERY_S3_SSL=false
# BYTEFREEZER_QUERY_S3_URL_STYLE=path

# LLM Configuration
BYTEFREEZER_QUERY_LLM_PROVIDER=anthropic
BYTEFREEZER_QUERY_LLM_API_KEY=your-api-key
BYTEFREEZER_QUERY_LLM_MODEL=claude-sonnet-4-20250514

# For OpenAI
# BYTEFREEZER_QUERY_LLM_PROVIDER=openai
# BYTEFREEZER_QUERY_LLM_API_KEY=your-openai-key
# BYTEFREEZER_QUERY_LLM_MODEL=gpt-4

# For Ollama (local)
# BYTEFREEZER_QUERY_LLM_PROVIDER=ollama
# BYTEFREEZER_QUERY_LLM_OLLAMA_HOST=http://localhost:11434
# BYTEFREEZER_QUERY_LLM_MODEL=llama2

# Server
BYTEFREEZER_QUERY_SERVER_PORT=8000

# Logging
BYTEFREEZER_QUERY_LOGGING_LEVEL=info
